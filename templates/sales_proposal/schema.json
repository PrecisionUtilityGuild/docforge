{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["title", "client", "executive_summary", "scope", "timeline", "pricing"],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "client": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "contact": { "type": "string" },
        "email": { "type": "string" }
      }
    },
    "date": { "type": "string" },
    "executive_summary": { "type": "string", "minLength": 1 },
    "scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["item"],
        "additionalProperties": false,
        "properties": {
          "item": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "timeline": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["phase", "duration"],
        "additionalProperties": false,
        "properties": {
          "phase": { "type": "string" },
          "duration": { "type": "string" },
          "deliverables": { "type": "string" }
        }
      }
    },
    "pricing": {
      "type": "object",
      "required": ["line_items", "total"],
      "additionalProperties": false,
      "properties": {
        "line_items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["item", "amount"],
            "additionalProperties": false,
            "properties": {
              "item": { "type": "string" },
              "amount": { "type": "string" },
              "notes": { "type": "string" }
            }
          }
        },
        "subtotal": { "type": "string" },
        "total": { "type": "string" },
        "terms": { "type": "string" }
      }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next_steps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "discovery_notes": { "type": "string" },
    "diagram": {
      "type": "object",
      "required": ["type", "nodes", "edges"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["process", "flowchart", "tree"] },
        "title": { "type": "string" },
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "label"],
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
