{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["title", "severity", "summary", "timeline", "impact", "root_cause", "actions"],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "incident_id": { "type": "string" },
    "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "date": { "type": "string" },
    "summary": { "type": "string", "minLength": 1 },
    "timeline": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["time", "event"],
        "additionalProperties": false,
        "properties": {
          "time": { "type": "string" },
          "event": { "type": "string" }
        }
      }
    },
    "impact": {
      "type": "object",
      "required": ["duration"],
      "additionalProperties": false,
      "properties": {
        "users_affected": { "type": "string" },
        "duration": { "type": "string" },
        "services": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "root_cause": { "type": "string", "minLength": 1 },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" },
          "owner": { "type": "string" },
          "due": { "type": "string" },
          "status": { "type": "string", "enum": ["open", "in_progress", "done"] }
        }
      }
    },
    "evidence": { "type": "string" }
  }
}
