{
  "id": "project_status",
  "version": "1.0.0",
  "name": "Project Status Report",
  "description": "1–5 page weekly project status with RAG indicators, workstreams, blockers, and next steps",
  "category": "operations",
  "typst_version": ">=0.14.0",
  "packages": {},
  "page_budget": { "min": 1, "max": 5 },
  "inputs": [
    "title",
    "period",
    "author",
    "overall_rag",
    "summary",
    "workstreams",
    "blockers",
    "next_steps",
    "evidence"
  ],
  "outputs": ["pdf", "png_preview", "source_zip"],
  "accessibility": {
    "requires_alt_text": false,
    "requires_document_title": true
  }
}
