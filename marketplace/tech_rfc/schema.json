{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["title", "rfc_id", "status", "authors", "summary", "motivation", "specification", "alternatives", "unresolved_questions"],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "rfc_id": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["draft", "proposed", "accepted", "deprecated", "superseded"]
    },
    "authors": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "summary": { "type": "string", "minLength": 1 },
    "motivation": { "type": "string", "minLength": 1 },
    "specification": { "type": "string", "minLength": 1 },
    "alternatives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "description"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "unresolved_questions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "typst_snippets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "footer_note": { "type": "string", "maxLength": 500 }
      }
    }
  }
}
