{
  "id": "sales_proposal",
  "version": "1.0.0",
  "name": "Sales Proposal",
  "description": "5–15 page client proposal with scope, timeline, pricing, and assumptions",
  "category": "business",
  "typst_version": ">=0.14.0",
  "packages": {},
