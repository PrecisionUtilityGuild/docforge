{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["title", "summary", "body_md"],
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Short note title"
    },
    "author": {
      "type": "string",
      "description": "Author or generator name in the header"
    },
    "date": {
      "type": "string",
      "description": "Note date"
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "One-paragraph summary"
    },
    "body_md": {
      "type": "string",
      "minLength": 1,
      "description": "Markdown note body rendered safely"
    },
    "equations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "latex"],
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string" },
          "latex": { "type": "string" },
          "alt": { "type": "string" }
        }
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["citation"],
        "additionalProperties": false,
        "properties": {
          "citation": { "type": "string" },
          "url": { "type": "string" }
        }
      }
    }
  }
}
