{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "title",
    "period",
    "author",
    "overall_rag",
    "summary",
    "workstreams",
    "blockers",
    "next_steps"
  ],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "period": { "type": "string", "minLength": 1 },
    "author": { "type": "string", "minLength": 1 },
    "overall_rag": { "type": "string", "enum": ["red", "amber", "green"] },
    "summary": { "type": "string", "minLength": 1 },
    "workstreams": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "status", "rag", "notes"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string" },
          "rag": { "type": "string", "enum": ["red", "amber", "green"] },
          "notes": { "type": "string" }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next_steps": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "evidence": {
      "type": "array",
      "description": "Grounding ledger: source snippets that support RAG, blockers, and next steps.",
      "items": {
        "type": "object",
        "required": ["type", "source", "quote"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["rag", "blocker", "next_step", "workstream"]
          },
          "source": { "type": "string", "minLength": 1 },
          "quote": { "type": "string", "minLength": 1 },
          "permalink": { "type": "string" }
        }
      }
    },
    "source_audit": {
      "type": "object",
      "description": "Reviewer-facing grounding diagnostics computed from the source evidence.",
      "required": ["confidence", "evidence_count", "sources", "coverage", "warnings"],
      "additionalProperties": false,
      "properties": {
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
        "evidence_count": { "type": "number", "minimum": 0 },
        "sources": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "coverage": {
          "type": "object",
          "required": ["rag", "blocker", "next_step", "workstream"],
          "additionalProperties": false,
          "properties": {
            "rag": { "type": "number", "minimum": 0 },
            "blocker": { "type": "number", "minimum": 0 },
            "next_step": { "type": "number", "minimum": 0 },
            "workstream": { "type": "number", "minimum": 0 }
          }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "typst_snippets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "footer_note": { "type": "string", "maxLength": 500 }
      }
    }
  }
}
