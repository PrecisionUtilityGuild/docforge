{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["title", "date", "attendees", "objective", "agenda", "prep_items", "background"],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "date": { "type": "string", "minLength": 1 },
    "attendees": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "objective": { "type": "string", "minLength": 1 },
    "agenda": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["topic", "duration"],
        "additionalProperties": false,
        "properties": {
          "topic": { "type": "string" },
          "duration": { "type": "string" }
        }
      }
    },
    "prep_items": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "background": { "type": "string", "minLength": 1 },
    "typst_snippets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "footer_note": { "type": "string", "maxLength": 500 }
      }
    }
  }
}
