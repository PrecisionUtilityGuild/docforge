# Slack — socket mode (local: slack run or npm run slack)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
# SLACK_LOG_LEVEL=info

# Slack — HTTP mode (deploy). Set SLACK_SOCKET_MODE=false and omit SLACK_APP_TOKEN.
# SLACK_SOCKET_MODE=false
# SLACK_SIGNING_SECRET=your-signing-secret
# PORT=3000

# DocForge runtime (optional; defaults shown in README)
# DOCFORGE_DATA_ROOT=/var/forge/data
# DOCFORGE_TYPST_PATH=typst
# DOCFORGE_TYPST_PACKAGE_PATH=/absolute/path/to/vendor/typst-packages
# DOCFORGE_TYPST_PACKAGE_CACHE_PATH=/tmp/typst-package-cache
# DOCFORGE_COMPILE_TIMEOUT_MS=30000
# DOCFORGE_DOCUMENT_TTL_MS=86400000
# DOCFORGE_TEMPLATE_SOURCE_DIRS=/absolute/path/to/custom/templates

# Runtime limits
# DOCFORGE_MAX_DATA_BYTES=5242880
# DOCFORGE_MAX_CSV_BYTES=1048576
# DOCFORGE_MAX_ASSET_BYTES=10485760

# Forge MCP bridge
# FORGE_MCP=on
# FORGE_MCP_SERVER_ENTRY=/absolute/path/to/dist/index.js

# QA / local scripts
# DOCFORGE_VISUAL_THRESHOLD=0.02
# TYPST_VERSION_PIN=0.14.2
# POLL_MESSAGE_LIMIT=30
# POLL_OUTPUT=/tmp/forge-slack-poll.txt
# SEED_DELAY_MS=400
# SEED_INCIDENT_CHANNEL=incident-api-gateway
# SEED_SALES_CHANNEL=sales-northstar
# SEED_STATUS_CHANNEL=team-eng
# SEED_GENERAL_CHANNEL=general
