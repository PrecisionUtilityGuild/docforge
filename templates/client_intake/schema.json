{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["title", "client", "date", "contact", "objectives", "requirements", "constraints", "next_steps"],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "client": { "type": "string", "minLength": 1 },
    "date": { "type": "string", "minLength": 1 },
    "contact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string" }
      }
    },
    "objectives": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "next_steps": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "typst_snippets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "footer_note": { "type": "string", "maxLength": 500 }
      }
    }
  }
}
