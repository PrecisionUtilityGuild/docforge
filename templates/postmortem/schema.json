{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "title",
    "date",
    "severity",
    "summary",
    "timeline",
    "impact",
    "root_cause",
    "what_went_well",
    "what_went_wrong",
    "action_items",
    "lessons_learned"
  ],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "date": { "type": "string", "minLength": 1 },
    "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "summary": { "type": "string", "minLength": 1 },
    "timeline": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["time", "event"],
        "additionalProperties": false,
        "properties": {
          "time": { "type": "string" },
          "event": { "type": "string" }
        }
      }
    },
    "impact": {
      "type": "object",
      "required": ["duration"],
      "additionalProperties": false,
      "properties": {
        "users_affected": { "type": "string" },
        "duration": { "type": "string" },
        "services": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "root_cause": { "type": "string", "minLength": 1 },
    "what_went_well": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "what_went_wrong": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "action_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" },
          "owner": { "type": "string" },
          "due": { "type": "string" },
          "status": { "type": "string", "enum": ["open", "in_progress", "done"] }
        }
      }
    },
    "lessons_learned": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "typst_snippets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "footer_note": { "type": "string", "maxLength": 500 }
      }
    }
  }
}
