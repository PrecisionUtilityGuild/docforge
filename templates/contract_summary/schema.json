{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["title", "parties", "effective_date", "summary", "clauses", "key_dates"],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "parties": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["name", "role"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "role": { "type": "string" }
        }
      }
    },
    "effective_date": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "clauses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "body"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" },
          "body": { "type": "string" }
        }
      }
    },
    "key_dates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["label", "date"],
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string" },
          "date": { "type": "string" }
        }
      }
    },
    "typst_snippets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "footer_note": { "type": "string", "maxLength": 500 }
      }
    }
  }
}
