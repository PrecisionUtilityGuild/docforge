{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["title", "period", "cohorts", "insights"],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "period": { "type": "string", "minLength": 1 },
    "insights": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "cohorts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "size", "retention_rates"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "size": { "type": "integer", "minimum": 1 },
          "retention_rates": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "number", "minimum": 0, "maximum": 100 }
          }
        }
      }
    },
    "charts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "data"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["bar", "line", "area", "pie", "donut", "waterfall", "stacked_bar", "kpi_card"]
          },
          "title": { "type": "string" },
          "data": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["label", "value"],
              "additionalProperties": false,
              "properties": {
                "label": { "type": "string" },
                "value": { "type": ["string", "number"] }
              }
            }
          },
          "options": { "type": "object" }
        }
      }
    },
    "typst_snippets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "footer_note": { "type": "string", "maxLength": 500 }
      }
    }
  }
}
