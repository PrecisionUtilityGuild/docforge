{
  "id": "research_report",
  "version": "1.0.0",
  "name": "Research Report",
  "description": "10–30 page research report with abstract, findings, equations, and sources",
  "category": "business",
  "typst_version": ">=0.14.0",
  "packages": {
    "@preview/mitex": "0.2.7"
  },
  "page_budget": { "min": 4, "max": 30 },
  "inputs": ["title", "abstract", "sections", "findings", "sources"],
  "outputs": ["pdf", "png_preview", "source_zip"],
  "accessibility": {
    "requires_alt_text": false,
    "requires_document_title": true
  }
}
