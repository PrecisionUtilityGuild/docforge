{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["title", "period", "summary", "kpis", "commentary"],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "period": { "type": "string", "minLength": 1 },
    "author": { "type": "string" },
    "summary": { "type": "string", "minLength": 1 },
    "kpis": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "value"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "value": { "type": "string" },
          "unit": { "type": "string" },
          "target": { "type": "string" },
          "trend": { "type": "string", "enum": ["up", "down", "flat"] },
          "change": { "type": "string" }
        }
      }
    },
    "charts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "data"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["bar", "line", "area", "pie", "donut", "waterfall", "stacked_bar", "kpi_card"]
          },
          "title": { "type": "string" },
          "data": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["label", "value"],
              "additionalProperties": false,
              "properties": {
                "label": { "type": "string" },
                "value": { "type": ["string", "number"] }
              }
            }
          },
          "options": { "type": "object" }
        }
      }
    },
    "commentary": { "type": "string", "minLength": 1 },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description"],
        "additionalProperties": false,
        "properties": {
          "description": { "type": "string" },
          "severity": { "type": "string", "enum": ["low", "medium", "high"] },
          "mitigation": { "type": "string" }
        }
      }
    },
    "asks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" },
          "owner": { "type": "string" },
          "due": { "type": "string" }
        }
      }
    }
  }
}
