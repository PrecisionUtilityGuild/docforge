{
  "id": "meeting_brief",
  "version": "1.0.0",
  "name": "Meeting Brief",
  "description": "1–3 page meeting prep brief with attendees, agenda, prep items, and background",
  "category": "operations",
  "typst_version": ">=0.14.0",
  "packages": {},
  "page_budget": { "min": 1, "max": 3 },
  "inputs": ["title", "date", "attendees", "objective", "agenda", "prep_items", "background"],
  "outputs": ["pdf", "png_preview", "source_zip"],
  "accessibility": {
    "requires_alt_text": false,
    "requires_document_title": true
  }
}
