{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["title", "period", "summary", "line_items", "totals", "commentary"],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "period": { "type": "string", "minLength": 1 },
    "author": { "type": "string" },
    "summary": { "type": "string", "minLength": 1 },
    "line_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["category", "amount"],
        "additionalProperties": false,
        "properties": {
          "category": { "type": "string" },
          "amount": { "type": "string" }
        }
      }
    },
    "totals": {
      "type": "object",
      "required": ["revenue", "expenses", "net"],
      "additionalProperties": false,
      "properties": {
        "revenue": { "type": "string" },
        "expenses": { "type": "string" },
        "net": { "type": "string" }
      }
    },
    "charts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "data"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["bar", "line", "area", "pie", "donut", "waterfall", "stacked_bar", "kpi_card"]
          },
          "title": { "type": "string" },
          "data": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["label", "value"],
              "additionalProperties": false,
              "properties": {
                "label": { "type": "string" },
                "value": { "type": ["string", "number"] }
              }
            }
          },
          "options": { "type": "object" }
        }
      }
    },
    "commentary": { "type": "string", "minLength": 1 }
  }
}
